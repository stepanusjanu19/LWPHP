{% extends 'layout/base.twig' %}

{% block title %}System Tasks | LWPHP CMS{% endblock %}

{% block extra_css %}
.task-list { width: 100%; border-collapse: collapse; }
.task-list th, .task-list td { padding: 1rem; border-bottom: 1px solid var(--glass-border); text-align: left; }
.task-list th { font-family: 'Outfit', sans-serif; color: var(--text-muted); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
.status-badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold; background: rgba(255,255,255,0.1); }
.status-pending { color: #f59e0b; background: rgba(245, 158, 11, 0.1); }
.status-running { color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
.status-completed { color: #10b981; background: rgba(16, 185, 129, 0.1); }
.status-failed { color: #ef4444; background: rgba(239, 68, 68, 0.1); }
{% endblock %}

{% block content %}
<div class="dashboard-grid">
    <aside class="sidebar glass-card">
        <div class="user-profile">
            <div class="avatar">{{ username|default('A')|slice(0,1)|upper }}</div>
            <div>
                <p style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Admin Provider</p>
                <p style="font-weight: 600; font-family: 'Outfit', sans-serif; font-size: 1.1rem; line-height: 1.2;">{{ username|default('admin') }}</p>
            </div>
        </div>
        {% include 'partials/sidebar.twig' with {'active_page': 'tasks'} %}
    </aside>

    <div class="main-content">
        <div class="glass-card">
            <h2 style="font-family: 'Outfit', sans-serif; margin-bottom: 1.5rem;">System Tasks</h2>
            
            <table class="task-list">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Created At</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                    <tr>
                        <td class="font-mono text-gray-400">{{ item.id }}</td>
                        <td>{{ item.title }}</td>
                        <td><span class="status-badge status-{{ item.status }}">{{ item.status_label|upper }}</span></td>
                        <td>{{ item.priority }}</td>
                        <td class="text-sm text-gray-400">{{ item.created_at }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 2rem;">No system tasks found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
