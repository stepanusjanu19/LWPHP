{% extends 'layout/base.twig' %}

{% block title %}Dashboard | LWPHP CMS{% endblock %}

{% block extra_css %}

.stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
}

.stat-card {
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    border-color: rgba(79, 70, 229, 0.4);
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    opacity: 0;
    transition: opacity 0.3s;
}

.stat-card:hover::before {
    opacity: 1;
}

.stat-icon {
    position: absolute;
    right: 1.5rem;
    top: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(79, 70, 229, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
}

.stat-card h4 {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
}

.stat-card .value {
    font-size: 2.25rem;
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    color: var(--text-main);
}

.stat-trend {
    font-size: 0.85rem;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
}

.generator-section {
    padding: 2.5rem;
    border-radius: 16px;
    background: linear-gradient(145deg, var(--card-bg), rgba(24, 24, 27, 0.4));
    position: relative;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05);
}

.generator-section::after {
    content: '';
    position: absolute;
    right: -50px;
    top: -50px;
    width: 200px;
    height: 200px;
    background: var(--primary-glow);
    filter: blur(50px);
    border-radius: 50%;
    pointer-events: none;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
}

.form-control {
    background: rgba(0,0,0,0.2) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    color: white !important;
    padding: 0.85rem 1rem !important;
    border-radius: 10px !important;
    font-family: 'Inter', sans-serif;
    transition: border-color 0.3s, box-shadow 0.3s;
}

.form-control:focus {
    outline: none;
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.25);
}

.btn-group {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark)) !important;
    box-shadow: var(--shadow-sm) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
}

.btn-accent {
    background: linear-gradient(135deg, var(--accent), #9333ea) !important;
    box-shadow: var(--shadow-sm) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
}

.console-output {
    background: #09090b;
    color: var(--success);
    font-family: 'Fira Code', 'Courier New', monospace;
    padding: 1.25rem;
    border-radius: 12px;
    margin-top: 2rem;
    font-size: 0.85rem;
    min-height: 120px;
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
}

.console-output::-webkit-scrollbar {
    width: 6px;
}
.console-output::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.2);
    border-radius: 3px;
}
{% endblock %}

{% block content %}
<div class="dashboard-grid">
    <aside class="sidebar glass-card">
        <div class="user-profile">
            <div class="avatar">{{ username|slice(0,1)|upper }}</div>
            <div>
                <p style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Admin Provider</p>
                <p style="font-weight: 600; font-family: 'Outfit', sans-serif; font-size: 1.1rem; line-height: 1.2;">{{ username }}</p>
            </div>
        </div>
        {% include 'partials/sidebar.twig' with {'active_page': 'overview'} %}
    </aside>

    <div class="main-content">
        <h1 style="font-family: 'Outfit', sans-serif; font-size: 2.2rem; margin-bottom: 2rem;">Dashboard Overview</h1>
        
        <div class="stats-row">
            <div class="glass-card stat-card">
                <div class="stat-icon">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </div>
                <h4>Total Posts</h4>
                <div class="value">{{ total_posts }}</div>
                <div class="stat-trend"><svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg> Active</div>
            </div>
            <div class="glass-card stat-card">
                <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--accent);">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
                <h4>Active Users</h4>
                <div class="value">{{ total_users }}</div>
                <div class="stat-trend" style="color: var(--text-muted);"><svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg> Steady</div>
            </div>
            <div class="glass-card stat-card">
                <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h4>System Load</h4>
                <div class="value">{{ sys_load }}</div>
                <div class="stat-trend" style="color: var(--accent);"><svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path></svg> Optimized</div>
            </div>
        </div>

        <section class="generator-section glass-card">
            <h2 style="font-family: 'Outfit', sans-serif; font-size: 1.5rem; margin-bottom: 0.5rem; color: #fff;">Interactive CMS Generator</h2>
            <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 0.95rem;">Use the advanced RPC Gateway to dynamically scaffold your application components, routing, and UI schemas immediately.</p>
            
            <div class="form-group">
                <label>Target Resource Name</label>
                <div style="display: flex; gap: 1rem;">
                    <input type="text" id="gen_name" class="form-control" style="flex: 1;" placeholder="e.g. Testimonial, Product, Ticket" autocomplete="off">
                </div>
            </div>
            
            <div class="btn-group">
                <button onclick="runRpc('generateCrud')" class="btn btn-primary" style="display: flex; gap: 0.5rem; align-items: center; color: white;">
                    <svg style="width:18px;height:18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                    Generate Full Entity CRUD
                </button>
                <button onclick="runRpc('generateLivewire')" class="btn btn-accent" style="display: flex; gap: 0.5rem; align-items: center; color: white;">
                    <svg style="width:18px;height:18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Generate Reactive Livewire
                </button>
            </div>

            <div id="rpc_output" class="console-output" style="display: none;">
                <div style="color: var(--text-muted); margin-bottom: 0.5rem;">> Terminal ready... waiting for input</div>
            </div>
        </section>

    </div>
</div>

<script>
async function runRpc(method) {
    const name = document.getElementById('gen_name').value;
    if (!name) {
        alert('Please enter a resource name');
        return;
    }

    const outputDiv = document.getElementById('rpc_output');
    outputDiv.style.display = 'block';
    outputDiv.innerHTML = '<div style="color: var(--text-muted);">[RPC] Calling GeneratorService::' + method + '("' + name + '")...</div>';

    try {
        const response = await fetch('/rpc', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '{{ csrf_token }}'
            },
            body: JSON.stringify({
                jsonrpc: '2.0',
                service: 'GeneratorService',
                method: method,
                params: [name],
                id: Date.now()
            })
        });

        const data = await response.json();
        
        if (data.result && data.result.success) {
            outputDiv.innerHTML += '<div style="color: #10b981; margin-top: 10px;">✔ Success! Components created successfully. Updating Sidebar real-time...</div>';
            outputDiv.innerHTML += '<pre style="margin-top: 10px; color: #d1d5db; white-space: pre-wrap;">' + data.result.message + '</pre>';
            
            // Generate exact frontend equivalent of backend slug/pascal variables
            const pascalName = name.split(/[-_ ]+/).map(w => w.charAt(0).toUpperCase() + w.slice(1)).join('') + 's';
            const slug = name.split(/[-_ ]+/).map(w => w.toLowerCase()).join('_') + 's';
            
            // Build the DOM Node
            const li = document.createElement('li');
            li.innerHTML = '<a href="/' + slug + '" style="padding: 0.6rem 1rem; font-size: 0.85rem; transition: background-color 0.5s ease; display:flex; align-items:center; gap:0.75rem; text-decoration:none; color:var(--text-muted); border-radius:10px;"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width: 16px; height: 16px; opacity:0.7;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg> ' + pascalName + '</a>';
            
            // Append and animate seamlessly
            const subnav = document.querySelector('.sidebar-subnav');
            if (subnav) {
                subnav.appendChild(li);
                const anchor = li.querySelector('a');
                anchor.style.backgroundColor = 'rgba(79, 70, 229, 0.25)';
                anchor.style.color = '#fff';
                setTimeout(() => {
                    anchor.style.backgroundColor = 'transparent';
                    anchor.style.color = 'var(--text-muted)';
                }, 2500);
            }
        } else {
            outputDiv.innerHTML += '<div style="color: #ef4444; margin-top: 10px;">✖ Error: ' + (data.error ? data.error.message : 'Unknown generator error') + '</div>';
        }
    } catch (err) {
        outputDiv.innerHTML += '<div style="color: #ef4444; margin-top: 10px;">✖ Network Error: ' + err.message + '</div>';
    }
}
</script>
{% endblock %}
