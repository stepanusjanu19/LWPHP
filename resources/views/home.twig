{% extends 'layout/base.twig' %}

{% block title %}LWPHP | Lightweight PHP Framework{% endblock %}

{% block extra_css %}
.hero {
    padding: 8rem 0;
    text-align: center;
}

.hero h1 {
    font-family: 'Outfit', sans-serif;
    font-size: 4.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.1;
}

.hero p {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
}

.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
}

.feature-card h3 {
    margin-bottom: 1rem;
    font-family: 'Outfit', sans-serif;
    color: var(--primary);
}

.testimonials {
    margin-top: 6rem;
    text-align: center;
}

.testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    margin-top: 3rem;
    text-align: left;
}

.testimonial-card p {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-main);
    margin-bottom: 1.5rem;
}

.testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--primary));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
}

.glow-point {
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
    top: -100px;
    left: -100px;
    z-index: -1;
    pointer-events: none;
}

@media (max-width: 768px) {
    .hero {
        padding: 4rem 0;
    }
    .hero h1 {
        font-size: 2.8rem;
    }
    .hero p {
        font-size: 1.1rem;
    }
    .features {
        grid-template-columns: 1fr;
    }
    .testimonials-grid {
        grid-template-columns: 1fr;
    }
    div[style*="display: flex; gap: 1.5rem; justify-content: center;"] {
        flex-direction: column;
        gap: 1rem !important;
    }
    div[style*="display: flex; gap: 1.5rem; justify-content: center;"] a {
        width: 100%;
        text-align: center;
    }
}
{% endblock %}

{% block content %}
<section class="hero">
    <div class="glow-point"></div>
    <h1>{{ hero.headline|default('Lightweight PHP <br>Framework')|raw }}</h1>
    <p>{{ hero.subheadline|default('Elegant design, simple architecture, and blazing fast performance. The next generation of PHP development starts here.') }}</p>
    <div style="display: flex; gap: 1.5rem; justify-content: center;">
        <a href="{{ hero.buttonUrl|default('/admin') }}" class="btn" style="padding: 1rem 2.5rem; font-size: 1.1rem;">{{ hero.buttonText|default('Get Started') }}</a>
        <a href="/docs" class="btn btn-outline" style="padding: 1rem 2.5rem; font-size: 1.1rem;">Documentation</a>
    </div>
</section>

<div class="features">
    {% for feature in features %}
    <div class="glass-card feature-card">
        <h3>
            {% if feature.icon %}
            <span style="margin-right: 0.5rem;">{{ feature.icon|raw }}</span>
            {% endif %}
            {{ feature.title }}
        </h3>
        <p>{{ feature.description }}</p>
    </div>
    {% else %}
    <div class="glass-card feature-card">
        <h3>Deploy the Generator</h3>
        <p>No features added yet. Log into the CMS Dashboard to run the RPC Gateway and scaffold components!</p>
    </div>
    {% endfor %}
</div>

{% if testimonials|length > 0 %}
<section class="testimonials">
    <h2 style="font-family: 'Outfit', sans-serif; font-size: 2.5rem; margin-bottom: 1rem;">What Developers Are Saying</h2>
    <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Join the growing community building faster, more beautiful web applications with LWPHP.</p>
    
    <div class="testimonials-grid">
        {% for testimonial in testimonials %}
        <div class="glass-card testimonial-card">
            <p>"{{ testimonial.content }}"</p>
            <div class="testimonial-author">
                <div class="author-avatar">{{ testimonial.authorName|slice(0, 1)|upper }}</div>
                <div>
                    <h4 style="margin: 0; font-size: 1rem; color: var(--text-main);">{{ testimonial.authorName }}</h4>
                    {% if testimonial.company %}
                        <span style="font-size: 0.85rem; color: var(--text-muted);">{{ testimonial.company }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% endif %}

{% endblock %}
